{
  "name": "netsute-ipaas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present build",
    "dev": "pnpm --filter @netsute/builder dev",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "latest",
    "globals": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
